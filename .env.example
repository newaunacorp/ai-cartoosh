# ============================================================
# AI CARTOOSH - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — only commit .env.example
# ============================================================

# DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/ai_cartoosh?schema=public"

# APP
NEXTAUTH_SECRET="generate-a-random-string-here-at-least-32-chars"
NEXT_PUBLIC_APP_URL="https://aicartoosh.com"
JWT_SECRET="generate-another-random-string-here"

# OPENAI - Text generation (GPT-4o) and Image generation (DALL-E 3)
OPENAI_API_KEY="sk-proj-your-key-here"

# ELEVENLABS - Voice synthesis
ELEVENLABS_API_KEY="your-elevenlabs-key-here"

# D-ID - Talking avatar video generation
DID_API_KEY="your-did-api-key-here"

# HEYGEN - Ultra realistic video (Phase 2)
HEYGEN_API_KEY="your-heygen-key-here"

# STRIPE - Payments
STRIPE_SECRET_KEY="sk_live_your-key-here"
STRIPE_PUBLISHABLE_KEY="pk_live_your-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret-here"

# STRIPE PRICE IDS (create these in Stripe Dashboard)
STRIPE_PRICE_CREATOR="price_creator_id_here"
STRIPE_PRICE_PRO="price_pro_id_here"
STRIPE_PRICE_STUDIO="price_studio_id_here"
STRIPE_PRICE_ENTERPRISE="price_enterprise_id_here"
STRIPE_PRICE_CREDITS_50="price_credits_50_here"
STRIPE_PRICE_CREDITS_150="price_credits_150_here"
STRIPE_PRICE_CREDITS_400="price_credits_400_here"
STRIPE_PRICE_CREDITS_1000="price_credits_1000_here"
STRIPE_PRICE_CREDITS_3000="price_credits_3000_here"
