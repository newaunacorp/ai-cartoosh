// AI Cartoosh - Complete Database Schema
// This is the single source of truth for all database tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  passwordHash          String
  displayName           String
  bio                   String?
  profileImage          String?
  subscriptionTier      SubscriptionTier @default(FREE)
  creditBalance         Int      @default(15)
  monthlyCreditsUsed    Int      @default(0)
  monthlyCreditsResetAt DateTime @default(now())
  storageUsedMb         Float    @default(0)
  referralCode          String   @unique
  referredBy            String?
  totalReferrals        Int      @default(0)
  stripeCustomerId      String?
  creatorEarningsTotal  Float    @default(0)
  creatorPayoutAvail    Float    @default(0)
  hasCompletedOnboarding Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  avatars              Avatar[]
  contentPlans         ContentPlan[]
  postScripts          PostScript[]
  aafs                 AAF[]            @relation("CreatedAAFs")
  ownedAAFs            AAFOwnership[]
  ideas                Idea[]
  interactions         Interaction[]
  creditTransactions   CreditTransaction[]
  subscription         Subscription?
  creatorEarnings      CreatorEarning[]
  renderJobs           RenderJob[]
  referralsMade        Referral[]       @relation("Referrer")
  referralsReceived    Referral[]       @relation("Referred")
  upgradePromptLogs    UpgradePromptLog[]
}

enum SubscriptionTier {
  FREE
  CREATOR
  PRO
  STUDIO
  ENTERPRISE
}

// ============================================================
// AVATARS
// ============================================================

model Avatar {
  id                   String   @id @default(uuid())
  userId               String
  name                 String
  description          String?
  personality          String
  avatarImage          String?
  avatarGenerationMethod AvatarGenMethod @default(PRESET)
  voiceStyle           VoiceStyle @default(PROFESSIONAL)
  defaultVoiceId       String?
  language             String   @default("English")
  worldSetting         String?
  formalityLevel       Int      @default(50)
  energyLevel          Int      @default(50)
  humorLevel           Int      @default(50)
  verbosityLevel       Int      @default(50)
  isActive             Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentPlans         ContentPlan[]
  postScripts          PostScript[]
  renderJobs           RenderJob[]
}

enum AvatarGenMethod {
  UPLOAD
  PRESET
  AI_GENERATED
}

enum VoiceStyle {
  PROFESSIONAL
  CASUAL
  ENERGETIC
  CALM
  COMEDIC
  DRAMATIC
}

// ============================================================
// CONTENT PLANS (PSCPs)
// ============================================================

model ContentPlan {
  id          String   @id @default(uuid())
  userId      String
  avatarId    String
  planName    String
  planType    PlanType
  genre       String?
  description String
  ideas       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar      Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  postScripts PostScript[]
}

enum PlanType {
  PERSONAL
  BUSINESS
  SPORTS
  HOBBY
  NEWS
  ENTERTAINMENT
  EDUCATION
}

// ============================================================
// POSTSCRIPTS
// ============================================================

model PostScript {
  id              String   @id @default(uuid())
  userId          String
  avatarId        String
  planId          String
  scriptType      ScriptType
  sourceText      String?
  sourceMediaUrl  String?
  generatedOutput String?
  audioUrl        String?
  videoUrl        String?
  voiceId         String?
  outputFormat    OutputFormat @default(TEXT)
  status          PostScriptStatus @default(DRAFT)
  loopDuration    LoopDuration?
  loopIteration   Int      @default(1)
  loopParentId    String?
  views           Int      @default(0)
  likes           Int      @default(0)
  shares          Int      @default(0)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar          Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  contentPlan     ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  loopParent      PostScript? @relation("LoopChain", fields: [loopParentId], references: [id])
  loopChildren    PostScript[] @relation("LoopChain")
  interactions    Interaction[]
  renderJob       RenderJob?
}

enum ScriptType {
  VERBATIM
  INTERPRETIVE
}

enum OutputFormat {
  TEXT
  AUDIO
  VIDEO
}

enum PostScriptStatus {
  DRAFT
  GENERATING
  PUBLISHED
  ARCHIVED
}

enum LoopDuration {
  SHORT
  MEDIUM
  LONG
}

// ============================================================
// INTERACTIONS
// ============================================================

model Interaction {
  id            String   @id @default(uuid())
  postScriptId  String
  userId        String
  type          InteractionType
  commentText   String?
  createdAt     DateTime @default(now())

  postScript    PostScript @relation(fields: [postScriptId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InteractionType {
  LIKE
  SHARE
  COMMENT
  REACTION
}

// ============================================================
// AAF MARKETPLACE
// ============================================================

model AAF {
  id          String   @id @default(uuid())
  creatorId   String
  name        String
  description String
  category    AAFCategory
  aafData     String
  price       Float    @default(0)
  rating      Float    @default(0)
  downloads   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User     @relation("CreatedAAFs", fields: [creatorId], references: [id], onDelete: Cascade)
  ownerships  AAFOwnership[]
}

enum AAFCategory {
  PERSONALITY
  HABITS
  SCRIPTS
  INTERACTIONS
  LANGUAGE
  PROFILE
  FEATURES
}

model AAFOwnership {
  id        String   @id @default(uuid())
  userId    String
  aafId     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aaf       AAF      @relation(fields: [aafId], references: [id], onDelete: Cascade)

  @@unique([userId, aafId])
}

// ============================================================
// IDEAS
// ============================================================

model Idea {
  id          String   @id @default(uuid())
  creatorId   String
  name        String
  description String
  purpose     String?
  tips        String?
  price       Float    @default(0)
  isPublished Boolean  @default(false)
  rating      Float    @default(0)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

// ============================================================
// MONETIZATION
// ============================================================

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @unique
  planTier             SubscriptionTier
  status               SubStatus @default(ACTIVE)
  stripeSubscriptionId String?
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  monthlyCreditsAllowance Int
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIAL
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        CreditTransactionType
  credits     Int
  dollarAmount Float?
  description String
  relatedPostScriptId String?
  relatedAafId        String?
  stripePaymentId     String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CreditTransactionType {
  PURCHASE
  SUBSCRIPTION_GRANT
  SPEND
  REFUND
  REFERRAL_BONUS
  CREATOR_EARNING
}

model CreatorEarning {
  id                String   @id @default(uuid())
  creatorId         String
  sourceType        EarningSource
  grossAmount       Float
  platformCommission Float
  netAmount         Float
  commissionRate    Float
  buyerId           String?
  status            EarningStatus @default(PENDING)
  payoutId          String?
  createdAt         DateTime @default(now())

  creator           User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

enum EarningSource {
  AAF_SALE
  IDEA_SALE
  LOOP_AD_REVENUE
  TIP
  DIVIDEND
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID_OUT
  DISPUTED
}

// ============================================================
// RENDER PIPELINE
// ============================================================

model RenderJob {
  id              String   @id @default(uuid())
  userId          String
  avatarId        String
  postScriptId    String   @unique
  provider        RenderProvider
  providerJobId   String?
  status          RenderStatus @default(QUEUED)
  avatarType      AvatarRenderType
  durationSeconds Int?
  resolution      String   @default("720p")
  watermark       Boolean  @default(true)
  creditsCharged  Int
  audioUrl        String?
  resultVideoUrl  String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar          Avatar     @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  postScript      PostScript @relation(fields: [postScriptId], references: [id], onDelete: Cascade)
}

enum RenderProvider {
  DID
  HEYGEN
}

enum RenderStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AvatarRenderType {
  CARTOON
  STANDARD
  REALISTIC
  ULTRA_REALISTIC
}

// ============================================================
// VOICE LIBRARY
// ============================================================

model Voice {
  id            String   @id @default(uuid())
  elevenLabsId  String   @unique
  displayName   String
  description   String?
  gender        Gender
  style         VoiceStyle
  sampleAudioUrl String?
  minimumTier   SubscriptionTier @default(FREE)
  isActive      Boolean  @default(true)
}

enum Gender {
  MALE
  FEMALE
  NEUTRAL
}

// ============================================================
// REFERRALS
// ============================================================

model Referral {
  id                    String   @id @default(uuid())
  referrerId            String
  referredId            String
  referrerCreditsAwarded Int     @default(25)
  referredCreditsAwarded Int     @default(10)
  createdAt             DateTime @default(now())

  referrer              User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred              User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
}

// ============================================================
// UPGRADE TRACKING
// ============================================================

model UpgradePromptLog {
  id            String   @id @default(uuid())
  userId        String
  triggerType   String
  currentTier   SubscriptionTier
  suggestedTier SubscriptionTier
  actionTaken   String
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
